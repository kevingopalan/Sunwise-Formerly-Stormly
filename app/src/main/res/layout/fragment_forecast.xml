<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ForecastFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false">
            <TextView
                android:id="@+id/locationDisplay"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="0dp"
                android:padding="16dp"
                android:background="?attr/colorSurfaceContainer"
                android:text="Location"
                android:textColor="?attr/colorOnSurface"
                android:ellipsize="end"
                android:maxLines="1"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toStartOf="@+id/saveLocationButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:fontFamily="@font/montsemibold"/>

            <Button
                android:id="@+id/saveLocationButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginTop="0dp"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:background="?attr/colorSurfaceContainer"
                android:backgroundTint="?attr/colorSurfaceContainer"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:fontFamily="@font/montsemibold"
                android:textAllCaps="false"
                android:letterSpacing="0.02"
                android:text="Save"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                app:backgroundTint="?attr/colorSurfaceContainer"
                app:layout_constraintStart_toEndOf="@+id/locationDisplay"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/locationDisplay"/>

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/animation_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="120dp"
                app:layout_constraintHeight="80dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth="80dp"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/clear_day" />

            <TextView
                android:id="@+id/currentTempText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montbold"
                android:text="--º"
                android:textColor="?attr/colorOnSurface"
                android:theme="@style/Theme.Material3.Dark"
                android:textSize="72sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/animation_view" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/hltemps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="0dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/currentTempText">

                <TextView
                    android:id="@+id/highTempText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montsemibold"
                    android:layout_marginEnd="4dp"
                    android:text="---"
                    android:textColor="@color/df_high"
                    android:textSize="20sp"
                    app:layout_constraintEnd_toStartOf="@+id/slash"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toStartOf="@+id/lowTempText"
                    app:layout_constraintTop_toTopOf="parent"
                    android:textColor="?attr/colorOnSurface"
                    android:text="/"
                    android:id="@+id/slash"
                    android:textSize="20sp"/>

                <TextView
                    android:id="@+id/lowTempText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/montsemibold"
                    android:text="---"
                    android:textColor="@color/df_low"
                    android:textSize="20sp"
                    app:layout_constraintStart_toEndOf="@+id/slash"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/text_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/montsemibold"
                android:text="---"
                android:textAlignment="center"
                android:textColor="?attr/colorOnSurface"
                android:theme="@style/Theme.Material3.Dark"
                android:textSize="20sp"
                app:layout_constraintTop_toBottomOf="@id/hltemps"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:layout_editor_absoluteY="367dp" />

            <GridLayout
                android:id="@+id/basicinfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/main_background"
                android:columnCount="2"
                android:rowCount="2"
                android:padding="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_desc">

                <!-- Humidity Section -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:padding="8dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/humidityProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="0"
                        app:indicatorSize="72dp"
                        app:trackThickness="6dp"
                        app:indicatorColor="?attr/colorPrimary"
                        app:trackColor="?attr/colorSurfaceVariant"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/humidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montbold"
                        android:text="--%"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        app:layout_constraintBottom_toBottomOf="@+id/humidityProgress"
                        app:layout_constraintEnd_toEndOf="@+id/humidityProgress"
                        app:layout_constraintStart_toStartOf="@+id/humidityProgress"
                        app:layout_constraintTop_toTopOf="@+id/humidityProgress" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/montsemibold"
                        android:text="Humidity"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/humidityProgress" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Precipitation Section -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:padding="8dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/precipitationProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="0"
                        app:indicatorSize="72dp"
                        app:trackThickness="6dp"
                        app:indicatorColor="?attr/colorTertiary"
                        app:trackColor="?attr/colorSurfaceVariant"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/precipitation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montbold"
                        android:text="--%"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        app:layout_constraintBottom_toBottomOf="@+id/precipitationProgress"
                        app:layout_constraintEnd_toEndOf="@+id/precipitationProgress"
                        app:layout_constraintStart_toStartOf="@+id/precipitationProgress"
                        app:layout_constraintTop_toTopOf="@+id/precipitationProgress" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/montsemibold"
                        android:text="Precipitation"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/precipitationProgress" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Wind Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_wind_24"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/wind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montbold"
                        android:text="--mph"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montsemibold"
                        android:text="Wind"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Dew Point Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/humidityicon"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/dewpoint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montbold"
                        android:text="--°"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montsemibold"
                        android:text="Dew Point"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp" />
                </LinearLayout>

            </GridLayout>

            <TextView
                android:id="@+id/hourlyforecastlabel"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="Hourly Forecast"
                android:textSize="16dp"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/basicinfo" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/hourlyRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:orientation="horizontal"
                android:overScrollMode="never"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hourlyforecastlabel"
                tools:ignore="UnusedAttribute" />
            <TextView
                android:id="@+id/dailyforecastlabel"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="Daily Forecast"
                android:textSize="16dp"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hourlyRecyclerView" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dailyRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginLeft="20dp"
                android:clipToOutline="true"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="10dp"
                android:overScrollMode="never"
                android:background="@drawable/mbclip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/dailyforecastlabel"
                tools:ignore="UnusedAttribute" />

            <com.google.android.gms.ads.AdView
                android:id="@+id/forecast_ad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:adSize="MEDIUM_RECTANGLE"
                app:adUnitId="@string/ad_unit_forecast_fragment"
                app:layout_constraintTop_toBottomOf="@+id/dailyRecyclerView" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/hourlygraph"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/forecast_ad"
                android:layout_margin="20dp"
                android:padding="20dp"
                android:background="@drawable/main_background">
                <TextView
                    android:id="@+id/hourlygraphlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Hourly Forecast graph"
                    android:textSize="16dp"
                    android:textColor="?attr/colorOnSurface" />
                <!-- GraphView removed: using MPAndroidChart BarChart below -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/hourlyBarGraph"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:id="@+id/dailygraph"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hourlygraph"
                android:layout_margin="20dp"
                android:background="@drawable/main_background"
                android:fontFamily = "@font/montsemibold">
                <TextView
                    android:id="@+id/dailygraphlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Daily Forecast graph"
                    android:textSize="16dp"
                    android:textColor="?attr/colorOnSurface" />
                <!-- GraphView removed: using MPAndroidChart BarChart below -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/dailyBarGraph"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
            
            <View
                app:layout_constraintTop_toBottomOf="@id/dailygraph"
                android:layout_width="match_parent"
                android:layout_height="20dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/reloadFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/baseline_refresh_24"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary"
        app:fabSize="normal" />

    <LinearLayout
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="?android:colorBackground"
        android:gravity="center"
        android:orientation="vertical">
        <com.google.android.material.loadingindicator.LoadingIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorSize="64dp"/>

    </LinearLayout>

</FrameLayout>