<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipChildren="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:colorBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <AutoCompleteTextView
                    android:id="@+id/text_search"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:hint="Enter location"
                    android:inputType="textPostalAddress"
                    android:background="@drawable/main_background"
                    android:drawableStart="@drawable/baseline_search_24"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:fontFamily="@font/montsemibold"
                    android:textColor="?attr/colorOnSurface"
                    android:elevation="2dp"
                    android:layout_marginEnd="8dp"
                    android:ems="10"/>

                <Button
                    android:id="@+id/search"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:text="Go"
                    android:backgroundTint="?attr/colorSurfaceContainer"
                    app:backgroundTint="?attr/colorSurfaceContainer"
                    android:background="@drawable/main_background"
                    android:textColor="?attr/colorOnSurface"
                    android:letterSpacing="0.02"
                    android:textAllCaps="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:layout_gravity="center_vertical"
                    android:drawableEnd="@drawable/go" />
            </LinearLayout>

            <!-- suggestionsRecyclerView moved outside LinearLayout for overlap effect -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Your Location"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?attr/colorOnBackground" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/locationNeeded"
                android:visibility="gone">
                <include
                    layout="@layout/need_location_please"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    />
            </FrameLayout>

            <Button
                android:id="@+id/locationButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Detect Location"
                android:textColor="?attr/colorOnBackground"
                android:letterSpacing="0.02"
                android:background="@drawable/main_background"
                android:backgroundTint="?attr/colorSurfaceContainer"
                app:backgroundTint="?attr/colorSurfaceContainer"
                android:textAllCaps="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/detectedLocationRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Saved Locations"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?attr/colorOnBackground" />
            <EditText
                android:id="@+id/savedLocationsSearch"
                android:background="@drawable/main_background"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="8dp"
                android:hint="Search saved locations"
                android:inputType="textFilter" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/savedLocationsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:layout_marginTop="8dp" />
            <TextView
                android:id="@+id/noSavedLocationsPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="No saved locations yet. Search for a location above and add it to your saved list."
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:visibility="gone" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/animation_view"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/partly_cloudy_day" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Ensure progressBar overlay is last so it appears above all other views -->
    <LinearLayout
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone"
        android:background="?android:colorBackground"
        android:gravity="center"
        android:orientation="vertical">

        <com.google.android.material.loadingindicator.LoadingIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorSize="64dp"/>
    </LinearLayout>

</FrameLayout>